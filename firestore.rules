rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    function wasDataOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['phoneNumber', 'businessName', 'createdAt']);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['businessName']);
    }

    // Messages collection
    match /messages/{messageId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner()
        && request.resource.data.keys().hasAll(['text', 'sender', 'timestamp', 'userId']);
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow delete: if wasDataOwner();
    }

    // Inventory collection
    match /inventory/{itemId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow update: if wasDataOwner();
      allow delete: if wasDataOwner();
    }

    // Debts collection
    match /debts/{debtId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow update: if wasDataOwner();
      allow delete: if wasDataOwner();
    }
  }
}
